root = true

[*.{cs,vb}]

charset = utf-8
end_of_line = crlf
indent_style = space
indent_size = 4
max_line_length = 160
trim_trailing_whitespace = true


## Naming convention for private instance fields

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.underscored.capitalization = camel_case
dotnet_naming_style.underscored.required_prefix = _

dotnet_naming_rule.private_fields_underscored.symbols = private_fields
dotnet_naming_rule.private_fields_underscored.style = underscored
dotnet_naming_rule.private_fields_underscored.severity = warning

## Naming convention for public fields

dotnet_naming_symbols.public_fields.applicable_kinds = field
dotnet_naming_symbols.public_fields.applicable_accessibilities = public

dotnet_naming_style.camelcase.capitalization = camel_case

dotnet_naming_rule.public_fields_camelcase.symbols = public_fields
dotnet_naming_rule.public_fields_camelcase.style = camelcase
dotnet_naming_rule.public_fields_camelcase.severity = warning

## Naming convention for static fields

dotnet_naming_symbols.static_fields.applicable_kinds = field
dotnet_naming_symbols.static_fields.required_modifiers = static

dotnet_naming_style.pascalcase.capitalization = pascal_case

dotnet_naming_rule.static_fields_pascalcase.symbols = static_fields
dotnet_naming_rule.static_fields_pascalcase.style = pascalcase
dotnet_naming_rule.static_fields_pascalcase.severity = warning

## Naming convention for properties

dotnet_naming_symbols.properties.applicable_kinds = property

dotnet_naming_rule.properties_pascalcase.symbols = properties
dotnet_naming_rule.properties_pascalcase.style = pascalcase
dotnet_naming_rule.properties_pascalcase.severity = warning

## Naming convention for constants
dotnet_naming_symbols.constants.applicable_kinds = field
dotnet_naming_symbols.constants.required_modifiers = const

dotnet_naming_style.all_upper.capitalization = all_upper
dotnet_naming_style.all_upper.word_separator = _

dotnet_naming_rule.constants_all_upper.symbols = constants
dotnet_naming_rule.constants_all_upper.style = all_upper
dotnet_naming_rule.constants_all_upper.severity = warning

## Naming convention for methods, classes, interfaces, enums, structs and namespaces
dotnet_naming_symbols.methods.applicable_kinds = class, interface, enum, struct, namespace, method

dotnet_naming_rule.methods_pascalcase.symbols = methods
dotnet_naming_rule.methods_pascalcase.style = pascalcase
dotnet_naming_rule.methods_pascalcase.severity = warning
